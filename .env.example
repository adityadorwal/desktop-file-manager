# Dorwal AI — environment variables (optional / future use)
#
# This project runs fully offline by default.
# The variables below are placeholders for future cloud/AI integrations.

# Optional: OpenAI / local LLM endpoint (leave blank for offline mode)
LLM_API_KEY=
LLM_API_BASE=

# Optional: custom data directory (defaults to ./data/)
DATA_DIR=
